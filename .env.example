# --- Fixer.io (required for live rate ingestion) ---
FIXER_API_KEY=your_fixer_api_key
FIXER_STARTUP_ENABLED=true
FIXER_STARTUP_BACKFILL_DAYS=30

# Demo sample rates (used when FIXER_API_KEY is empty)
SAMPLE_RATES_ENABLED=true
SAMPLE_RATES_DAYS=30

# --- PostgreSQL ---
DATABASE_USER=exchange
DATABASE_PASSWORD=exchange
POSTGRES_DB=exchange_rates
POSTGRES_PORT=5432

# Backend JDBC (used when running backend outside Docker; Compose overrides host to "postgres")
DATABASE_URL=jdbc:postgresql://localhost:5432/exchange_rates

# --- Ollama / Spring AI ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_PORT=11434

# --- Backend ---
BACKEND_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Frontend (browser must reach the backend; use host machine URL from the browser) ---
API_URL=http://localhost:8080
FRONTEND_PORT=4200
